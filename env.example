:root{--blue:#0f4c81;--dark:#0b1f33;--light:#f3f7fb}
body{margin:0;background:var(--light);font-family:Arial,Helvetica,sans-serif;color:var(--dark)}
.app{max-width:580px;margin:auto;background:#fff;min-height:100vh}
.top{background:linear-gradient(160deg,#0f4c81,#0b1f33);color:white;padding:24px 18px 26px;border-bottom-left-radius:30px;border-bottom-right-radius:30px}
.brand{display:flex;gap:14px;align-items:center}.logo{width:70px;height:70px;border:3px solid white;border-radius:18px;font-weight:900;font-size:30px;display:flex;align-items:center;justify-content:center}
.card{background:white;margin:14px;padding:18px;border-radius:18px;box-shadow:0 8px 28px rgba(15,76,129,.13)}
button{display:block;width:100%;border:0;border-radius:14px;padding:14px;margin:8px 0;background:var(--blue);color:white;font-weight:800;font-size:15px}
.grid{display:grid;grid-template-columns:1fr 1fr}.grid .card{margin:8px}.grid b{display:block;color:var(--blue);font-size:22px}.grid span{font-size:13px}
